# Copy to .env for local development. Never commit real .env files.

# MariaDB connection used by app and scripts.
SQL_WORKFLOW_DB_HOST=127.0.0.1
SQL_WORKFLOW_DB_PORT=3307
SQL_WORKFLOW_DB_USER=workflow_user
SQL_WORKFLOW_DB_PASSWORD=change-me
SQL_WORKFLOW_DB_NAME=approval_workflow

# Docker Compose MariaDB template variables.
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=approval_workflow
MARIADB_USER=workflow_user
MARIADB_PASSWORD=change-me
MARIADB_HOST_PORT=3307

# LLM client used by the Streamlit workflow. Fill exactly one API key value
# in your ignored .env file before using Gemini.
SQL_WORKFLOW_LLM_PROVIDER=gemini_native
SQL_WORKFLOW_ENABLE_LLM_ADMIN=false
SQL_WORKFLOW_GEMINI_MODEL=gemini-3.1-flash-lite
GOOGLE_API_KEY=
GEMINI_API_KEY=
SQL_WORKFLOW_LLM_BASE_URL=
SQL_WORKFLOW_LLM_MODEL=
SQL_WORKFLOW_LLM_API_KEY=
SQL_WORKFLOW_LLM_TEMPERATURE=0
SQL_WORKFLOW_LLM_MAX_TOKENS=2048
SQL_WORKFLOW_LLM_TIMEOUT=180
SQL_WORKFLOW_LLM_ENABLE_THINKING=false

# Optional host-side llama.cpp launch profile. Docker Compose does not ship a model.
SQL_WORKFLOW_LLM_MODEL_PATH=models/local-model/model.gguf
SQL_WORKFLOW_LLAMA_N_GPU_LAYERS=999
SQL_WORKFLOW_LLAMA_CTX_SIZE=8192
SQL_WORKFLOW_LLAMA_HOST=127.0.0.1
SQL_WORKFLOW_LLAMA_PORT=8000
SQL_WORKFLOW_LLAMA_LOG_DIR=logs
SQL_WORKFLOW_LLAMA_SERVER_BIN=local_llama_server_binary

# Streamlit launch profile.
SQL_WORKFLOW_STREAMLIT_HOST=127.0.0.1
SQL_WORKFLOW_STREAMLIT_PORT=8501
SQL_WORKFLOW_STREAMLIT_LOG_DIR=logs
SQL_WORKFLOW_STREAMLIT_BIN=streamlit

# Optional alternate llama.cpp launch profile.
SQL_WORKFLOW_ALT_LLM_MODEL_PATH=models/alternate-local-model/model.gguf
SQL_WORKFLOW_ALT_LLM_MODEL=alternate-local-model
SQL_WORKFLOW_ALT_LLAMA_N_GPU_LAYERS=0
SQL_WORKFLOW_ALT_LLAMA_CTX_SIZE=8192
SQL_WORKFLOW_ALT_LLAMA_HOST=127.0.0.1
SQL_WORKFLOW_ALT_LLAMA_PORT=8001

# Local import inputs and metadata.
SQL_WORKFLOW_RAW_DATA_DIR=data/raw_unzipped
SQL_WORKFLOW_IMPORT_SCHEMA_PATH=path/to/local/schema.sql
SQL_WORKFLOW_IMPORT_ADVERTISER_CODE=PUBLIC_DEMO
SQL_WORKFLOW_IMPORT_REPORT_MONTH=YYYY-MM
SQL_WORKFLOW_IMPORT_BATCH_NAME=local_import
SQL_WORKFLOW_IMPORT_UPLOADED_BY=local
